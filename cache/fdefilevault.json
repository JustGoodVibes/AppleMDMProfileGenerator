{"abstract":[{"text":"The payload that configures FileVault.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"data","url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/FDEFileVault"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"FDEFileVault"}],"platforms":["Unsupported OS: macOS"],"languages":["data"]}]},{"items":[{"attributes":[],"required":false,"introducedVersion":"10.9.0","name":"Certificate","content":[{"inlineContent":[{"type":"text","text":"The DER-encoded certificate data if the system creates an institutional recovery key. This key isn’t supported on a Mac with Apple silicon."}],"type":"paragraph"}],"type":[{"kind":"text","text":"data"}]},{"required":false,"introducedVersion":"10.9.0","type":[{"kind":"text","text":"boolean"}],"name":"Defer","content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the system defers enabling FileVault until the designated user logs out. For details, see "},{"code":"fdesetup(8)","type":"codeVoice"},{"type":"text","text":". Only a local user or a mobile account user can enable FileVault."}],"type":"paragraph"}],"attributes":[{"kind":"default","value":"false"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the system prevents requests to enable FileVault at user logout time."}],"type":"paragraph"}],"required":false,"attributes":[{"kind":"default","value":"false"}],"name":"DeferDontAskAtUserLogout","introducedVersion":"10.9.0","type":[{"text":"boolean","kind":"text"}]},{"attributes":[{"value":"-1","kind":"minimum"},{"kind":"maximum","value":"9999"}],"introducedVersion":"10.9.0","content":[{"inlineContent":[{"type":"text","text":"The maximum number of times users can bypass enabling FileVault before the system requires the