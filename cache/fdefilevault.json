ssistant to enable FileVault at setup time."}]},{"inlineContent":[{"text":"To use this, enable the Await Device Configured ADE configuration option and send this profile with this key set, before sending the ","type":"text"},{"isActive":true,"identifier":"doc://com.apple.devicemanagement/documentation/DeviceManagement/DeviceConfiguredCommand","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An admin SecureToken user is required, otherwise the FileVault pane doesn’t appear.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Available: macOS 14+","type":"text"}]}],"introducedVersion":"10.9.0","required":false,"type":[{"kind":"text","text":"boolean"}],"attributes":[{"value":"false","kind":"default"}]},{"type":[{"text":"string","kind":"text"}],"content":[{"inlineContent":[{"text":"The path to the location of the recovery key and computer information property list.","type":"text"}],"type":"paragraph"}],"attributes":[],"name":"OutputPath","required":false,"introducedVersion":"10.9.0"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The password of the Open Directory user to add to FileVault. Use the "},{"type":"codeVoice","code":"UserEntersMissingInfo"},{"text":" key to prompt for this information.","type":"text"}]}],"name":"Password","introducedVersion":"10.9.0","type":[{"text":"string","kind":"text"}],"required":false,"attributes":[]},{"attributes":[],"required":false,"introducedVersion":"10.9.0","type":[{"kind":"text","text":"string"}],"name":"PayloadCertificateUUID","content":[{"type":"paragraph","inlineContent":[{"text":"The UUID of the payload within the same profile containing the asymmetric recovery key certificate payload.","type":"text"}]}]},{"type":[{"text":"boolean","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"type":"text","text":", the system prevents display of the personal recovery key to the user after the system enables FileVault."}]}],"attributes":[{"kind":"default","value":"true"}],"required":false,"introducedVersion":"10.9.0","name":"ShowRecoveryKey"},{"required":false,"introducedVersion":"10.9.0","name":"UseKeychain","content":[{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"type":"text","text":" and you don’t include certificate information in this payload, the system uses the keychain created at "},{"type":"codeVoice","code":"/Library/Keychains/FileVaultMaster.keychain"},{"type":"text","text":" when it adds the institutional recovery key."}],"type":"paragraph"}],"type":[{"kind":"text","text":"boolean"}],"attributes":[{"kind":"default","value":"false"}]},{"required":false,"introducedVersion":"10.9.0","type":[{"text":"boolean","kind":"text"}],"attributes":[{"kind":"default","value":"true"}],"name":"UseRecoveryKey","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the system creates a personal recovery key and displays it to the user."}]}]},{"attributes":[{"value":"false","kind":"default"}],"required":false,"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":", the system enables a prompt for missing user name or password fields."}]}],"introducedVersion":"10.9.0","name":"UserEntersMissingInfo","type":[{"kind":"text","text":"boolean"}]},{"attributes":[],"required":false,"name":"Username","introducedVersion":"10.9.0","type":[{"text":"string","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"text":"The user name of the Open Directory user to add to FileVault.","type":"text"}]}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Specify "},{"code":"com.apple.MCX.FileVault2","type":"codeVoice"},{"type":"text","text":" as th