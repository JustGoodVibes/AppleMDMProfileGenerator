{"kind":"symbol","hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.devicemanagement/documentation/DeviceManagement"]]},"identifier":{"url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/FDEFileVault","interfaceLanguage":"data"},"abstract":[{"type":"text","text":"The payload that configures FileVault."}],"variants":[{"paths":["/documentation/devicemanagement/fdefilevault"],"traits":[{"interfaceLanguage":"data"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"object ","kind":"text"},{"text":"FDEFileVault","kind":"identifier"}],"languages":["data"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"properties","title":"Properties","items":[{"introducedVersion":"10.9.0","type":[{"kind":"text","text":"data"}],"name":"Certificate","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The DER-encoded certificate data if the system creates an institutional recovery key. This key isn’t supported on a Mac with Apple silicon."}]}],"required":false,"attributes":[]},{"introducedVersion":"10.9.0","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":", the system defers enabling FileVault until the designated user logs out. For details, see "},{"code":"fdesetup(8)","type":"codeVoice"},{"type":"text","text":". Only a local user or a mobile account user can enable FileVault."}]}],"type":[{"kind":"text","text":"boolean"}],"name":"Defer","attributes":[{"value":"false","kind":"default"}],"required":false},{"required":false,"type":[{"text":"boolean","kind":"text"}],"name":"DeferDontAskAtUserLogout","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"text":", the system prevents requests to enable FileVault at user logout time.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Available: macOS 10.10+"}],"type":"paragraph"}],"attribut