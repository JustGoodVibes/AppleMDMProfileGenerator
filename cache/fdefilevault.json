{"kind":"symbol","identifier":{"interfaceLanguage":"data","url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/FDEFileVault"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.devicemanagement/documentation/DeviceManagement"]]},"metadata":{"role":"symbol","modules":[{"name":"Device Management"}],"symbolKind":"dictionary","fragments":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"FDEFileVault"}],"navigatorTitle":[{"kind":"identifier","text":"FDEFileVault"}],"externalID":"mdm-profiles:FDEFileVault","title":"FDEFileVault","roleHeading":"Device Management Profile","platforms":[{"beta":false,"introducedAt":"10.9","name":"macOS"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["data"],"platforms":["macOS"],"tokens":[{"text":"object ","kind":"text"},{"text":"FDEFileVault","kind":"identifier"}]}]},{"items":[{"introducedVersion":"10.9.0","type":[{"text":"data","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"text":"The DER-encoded certificate data if the system creates an institutional recovery key. This key isn’t supported on a Mac with Apple silicon.","type":"text"}]}],"name":"Certificate","attributes":[],"required":false},{"name":"Defer","type":[{"kind":"text","text":"boolean"}],"attributes":[{"value":"false","kind":"default"}],"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":", the system defers enabling FileVault until the designated user logs out. For details, see "},{"type":"codeVoice","code":"fdesetup(8)"},{"type":"text","text":". Only a local user or a mobile account user can enable FileVault."}]}],"required":false,"introducedVersion":"10.9.0"},{"attributes":[{"value":"false","kind":"default"}],"name":"DeferDontAskAtUserLogout","type":[{"text":"boolean","kind":"text"}],"required":false,"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":", the system prevents requests to enable FileVault at user logout time."}]}],"introducedVersion":"10.9.0"},{"type":[{"text":"integer","kind":"text"}],"required":false,"introducedVersion":"10.9.0","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The maximum number of times users can bypass enabling FileVault before the system requires the user to enable it to log in. If the value is "},{"type":"codeVoice","code":"0"},{"type":"text","text":", the system requires the user to enable FileVault the next time they attempt to log in. Set this key to "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" to disable this feature."}]}],"attributes":[{"kind":"minimum","value":"-1"},{"value":"9999","kind":"maximum"}],"name":"DeferForceAtUserLoginMaxBypassAttempts"},{"required":true,"type":[{"text":"string","kind":"text"}],"name":"Enable","introducedVersion":"10.9.0","attributes":[{"kind":"allowedValues","values":["On","Off"]}],"content":[{"type":"paragraph","inlineContent":[{"text":"Set to ","type":"text"},{"code":"On","type":"codeVoice"},{"type":"text","text":" to enable FileVault and set to "},{"type":"codeVoice","code":"Off"},{"text":" to disable FileVault. Payloads set to ","type":"text"},{"type":"codeVoice","code":"On"},{"text":" sent through MDM need to either include full authentication information in the payload or have the ","type":"text"},{"code":"Defer","type":"codeVoice"},{"text":" option set to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":". When ","type":"text"},{"code":"Defer","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the system prompts for the authentication information when the user enables FileVault."}]}]},{"type":[{"kind":"text","text":"boolean"}],"attributes":[{"value":"false","kind":"default"}],"introducedVersion":"10.9.0","required":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"text":", and installation of this payload occurs after enrolling with MDM in Setup Assistant, the system requests Setup Assistant to enable FileVault at setup time.","type":"text"}]},{"inlineContent":[{"text":"To use this, enable the Await Device Configured DEP configuration option and send this profile with this key set, before sending the ","type":"text"},{"identifier":"doc://com.apple.devicemanagement/documentation/DeviceManagement/DeviceConfiguredCommand","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An admin SecureToken user is required, otherwise the FileVault pane does not appear."}]}],"name":"ForceEnableInSetupAssistant"},{"name":"OutputPath","type":[{"text":"string","kind":"text"}],"content":[{"inlineContent":[{"text":"The path to the location of the recovery key and computer information property list.","type":"text"}],"type":"paragraph"}],"required":false,"attributes":[],"introducedVersion":"10.9.0"},{"required":false,"type":[{"kind":"text","text":"string"}],"introducedVersion":"10.9.0","content":[{"inlineContent":[{"text":"The password of the Open Directory user to add to FileVault. Use the ","type":"text"},{"type":"codeVoice","code":"UserEntersMissingInfo"},{"text":" key to prompt for this information.","type":"text"}],"type":"paragraph"}],"name":"Password","attributes":[]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The UUID of the payload within the same profile containing the asymmetric recovery key certificate payload."}]}],"attributes":[],"name":"PayloadCertificateUUID","required":false,"introducedVersion":"10.9.0","type":[{"kind":"text","text":"string"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", the system prevents display of the personal recovery key to the user after the system enables FileVault."}]}],"name":"ShowRecoveryKey","attributes":[{"value":"true","kind":"default"}],"introducedVersion":"10.9.0","required":false,"type":[{"text":"boolean","kind":"text"}]},{"attributes":[{"value":"false","kind":"default"}],"name":"UseKeychain","required":false,"introducedVersion":"10.9.0","type":[{"text":"boolean","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" and you don’t include certificate information in this payload, the system uses the keychain created at ","type":"text"},{"type":"codeVoice","code":"/Library/Keychains/FileVaultMaster.keychain"},{"text":" when it adds the institutional recovery key.","type":"text"}]}]},{"introducedVersion":"10.9.0","name":"UseRecoveryKey","required":false,"type":[{"text":"boolean","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":", the system creates a personal recovery key and displays it to the user."}]}],"attributes":[{"value":"true","kind":"default"}]},{"required":false,"attributes":[{"kind":"default","value":"false"}],"type":[{"text":"boolean","kind":"text"}],"introducedVersion":"10.9.0","name":"UserEntersMissingInfo","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"text":", the system enables a prompt for missing user name or password fields.","type":"text"}]}]},{"name":"Username","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The user name of the Open Directory user to add to FileVault."}]}],"required":false,"type":[{"kind":"text","text":"string"}],"attributes":[],"introducedVersion":"10.9.0"}],"kind":"properties","title":"Properties"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"Discussion"},{"inlineContent":[{"type":"text"