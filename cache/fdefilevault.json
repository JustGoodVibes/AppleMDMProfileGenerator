Management/DeviceConfiguredCommand"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An admin SecureToken user is required, otherwise the FileVault pane does not appear.","type":"text"}]}],"introducedVersion":"10.9.0","type":[{"text":"boolean","kind":"text"}],"attributes":[{"kind":"default","value":"false"}],"required":false},{"attributes":[],"introducedVersion":"10.9.0","content":[{"inlineContent":[{"text":"The path to the location of the recovery key and computer information property list.","type":"text"}],"type":"paragraph"}],"required":false,"name":"OutputPath","type":[{"text":"string","kind":"text"}]},{"type":[{"text":"string","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"text":"The password of the Open Directory user to add to FileVault. Use the ","type":"text"},{"type":"codeVoice","code":"UserEntersMissingInfo"},{"text":" key to prompt for this information.","type":"text"}]}],"attributes":[],"required":false,"introducedVersion":"10.9.0","name":"Password"},{"introducedVersion":"10.9.0","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The UUID of the payload within the same profile containing the asymmetric recovery key certificate payload."}]}],"required":false,"name":"PayloadCertificateUUID","type":[{"text":"string","kind":"text"}],"attributes":[]},{"type":[{"kind":"text","text":"boolean"}],"attributes":[{"value":"true","kind":"default"}],"required":false,"introducedVersion":"10.9.0","name":"ShowRecoveryKey","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":", the system prevents display of the personal recovery key to the user after the system enables FileVault."}]}]},{"attributes":[{"value":"false","kind":"default"}],"required":false,"name":"UseKeychain","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" and you don’t include certificate information in this payload, the system uses the keychain created at "},{"code":"/Library/Keychains/FileVaultMaster.keychain","type":"codeVoice"},{"text":" when it adds the institutional recovery key.","type":"text"}]}],"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.9.0"},{"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", the system creates a personal recovery key and displays it to the user.","type":"text"}]}],"name":"UseRecoveryKey","attributes":[{"kind":"default","value":"true"}],"type":[{"text":"boolean","kind":"text"}],"required":false,"introducedVersion":"10.9.0"},{"name":"UserEntersMissingInfo","content":[{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the system enables a prompt for missing user name or password fields."}],"type":"paragraph"}],"introducedVersion":"10.9.0","type":[{"kind":"text","text":"boolean"}],"attributes":[{"kind":"default","value":"false"}],"required":false},{"type":[{"text":"string","kind":"text"}],"content":[{"inlineContent":[{"text":"The user name of the Open Directory user to add to FileVault.","type":"text"}],"type":"paragraph"}],"required":false,"introducedVersion":"10.9.0","attributes":[],"name":"Username"}],"title":"Properties","kind":"properties"},{"kind":"content","content":[{"anchor":"Discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"Specify ","type":"text"},{"type":"codeVoice","code":"com.apple.MCX.FileVault2"},{"type":"text","text":" as the payload type."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"FileVault 2 performs full XTS-AES 128 encryption on the contents of a volume. Removing the FileVault payload doesn’t disable FileVault.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As of macOS 10.15, FileVault settings require supervision or user approval when installe