e.com"},{"text":": Any path under ","type":"text"},{"type":"codeVoice","code":"foo.example.com"},{"text":" matches, but not ","type":"text"},{"code":"example.com","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"bar.example.com"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"\\*.example.com"},{"type":"text","text":": Any path under "},{"type":"codeVoice","code":"foo.example.com"},{"type":"text","text":" or "},{"code":"bar.example.com","type":"codeVoice"},{"text":" matches, but not ","type":"text"},{"type":"codeVoice","code":"example.com"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"example.com/sub"},{"text":": ","type":"text"},{"code":"example.com/sub","type":"codeVoice"},{"type":"text","text":" and any path under it matches, but not "},{"code":"example.com","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"foo.example.com/sub"},{"text":": Any path under ","type":"text"},{"type":"codeVoice","code":"foo.example.com/sub"},{"text":" matches, but not ","type":"text"},{"type":"codeVoice","code":"example.com"},{"text":", ","type":"text"},{"code":"example.com/sub","type":"codeVoice"},{"type":"text","text":", "},{"code":"foo.example.com/","type":"codeVoice"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"bar.example.com/sub"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"\\*.example.com/sub"},{"type":"text","text":": Any path under "},{"type":"codeVoice","code":"foo.example.com/sub"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"bar.example.com/sub"},{"type":"text","text":" matches, but not "},{"type":"codeVoice","code":"example.com"},{"text":" or ","type":"text"},{"code":"foo.example.com/","type":"codeVoice"},{"type":"text","text":"."}]}]},{