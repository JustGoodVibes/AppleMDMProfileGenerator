{"metadata":{"title":"SmartCard","fragments":[{"text":"object ","kind":"text"},{"text":"SmartCard","kind":"identifier"}],"roleHeading":"Device Management Profile","navigatorTitle":[{"kind":"identifier","text":"SmartCard"}],"role":"symbol","externalID":"mdm-profiles:SmartCard","modules":[{"name":"Device Management"}],"symbolKind":"dictionary","platforms":[{"name":"macOS","introducedAt":"10.12.4","beta":false},{"name":"Device Assignment Services","beta":false},{"name":"VPP License Management","beta":false}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"data"}],"paths":["/documentation/devicemanagement/smartcard"]}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"text","text":"object "},{"kind":"identifier","text":"SmartCard"}],"platforms":["Unsupported OS: macOS"],"languages":["data"]}],"kind":"declarations"},{"title":"Properties","items":[{"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.12.4","name":"allowSmartCard","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect.","type":"text"}]}],"attributes":[{"kind":"default","value":"true"}],"required":false},{"content":[{"inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"0","type":"codeVoice"},{"type":"text","text":": Turns off certificate trust check."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"1","type":"codeVoice"},{"type":"text","text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revo