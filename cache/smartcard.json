{"identifier":{"interfaceLanguage":"data","url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/SmartCard"},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["Unsupported OS: macOS"],"languages":["data"],"tokens":[{"kind":"text","text":"object "},{"text":"SmartCard","kind":"identifier"}]}],"kind":"declarations"},{"items":[{"name":"allowSmartCard","type":[{"text":"boolean","kind":"text"}],"attributes":[{"kind":"default","value":"true"}],"required":false,"introducedVersion":"10.12.4","content":[{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect.","type":"text"}],"type":"paragraph"}]},{"attributes":[{"value":"0","kind":"default"},{"kind":"allowedValues","values":["0","1","2","3"]}],"type":[{"text":"integer","kind":"text"}],"introducedVersion":"10.12.4","required":false,"name":"checkCertificateTrust","content":[{"inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"0"},{"text":": Turns off certificate trust check.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1"},{"type":"text","text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revocation checks."}]}]},{"content":[{"inlineContent":[{"code":"2","type":"codeVoice"},{"type":"text","text":": Turns on certificate trust check. A soft revocation check is also performed. Until the certificate is explicitly rejected by CRL/OCSP, it’s considered valid. This setting means that unavailable or unreachable CRL/OCSP allow this check to s