}],"name":"tokenRemovalAction","introducedVersion":"10.12.4","required":false},{"attributes":[{"value":"true","kind":"default"}],"name":"UserPairing","type":[{"kind":"text","text":"boolean"}],"required":false,"introducedVersion":"10.12.4","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"text":", users don’t get the pairing dialog, although existing pairings still work.","type":"text"}]}]}],"kind":"properties"},{"content":[{"text":"Discussion","anchor":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Specify "},{"type":"codeVoice","code":"com.apple.security.smartcard"},{"text":" as the payload type.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Profile availability","anchor":"Profile-availability"},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[]}]],[[{"inlineContent":[{"text":"Device channel","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"User channel"}]}],[{"inlineContent":[{"text":"NA","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allow manual install"}]}],[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires supervision"}]}],[{"inlineContent":[{"type":"text","text":"NA"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Requires user-approved MDM"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allowed in user enrollment"}]}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"inlineContent":[{"text":"Allow multiple payloads","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineC