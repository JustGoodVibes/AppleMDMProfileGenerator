{"metadata":{"fragments":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"SmartCard"}],"navigatorTitle":[{"kind":"identifier","text":"SmartCard"}],"title":"SmartCard","role":"symbol","externalID":"mdm-profiles:SmartCard","platforms":[{"introducedAt":"10.12.4","beta":false,"name":"macOS"},{"beta":false,"name":"Device Assignment Services"},{"name":"VPP License Management","beta":false}],"modules":[{"name":"Device Management"}],"roleHeading":"Device Management Profile","symbolKind":"dictionary"},"seeAlsoSections":[{"identifiers":["doc://com.apple.devicemanagement/documentation/DeviceManagement/Passcode","doc://com.apple.devicemanagement/documentation/DeviceManagement/SecurityPreferences"],"generated":true,"title":"Security","anchor":"Security"}],"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.devicemanagement/documentation/DeviceManagement"]]},"abstract":[{"type":"text","text":"The payload that configures a smart card."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["data"],"tokens":[{"text":"object ","kind":"text"},{"text":"SmartCard","kind":"identifier"}],"platforms":["Unsupported OS: macOS"]}]},{"title":"Properties","kind":"properties","items":[{"attributes":[{"kind":"default","value":"true"}],"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.12.4","required":false,"name":"allowSmartCard","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect."}]}]},{"required":false,"introducedVersion":"10.12.4","type":[{"kind":"text","text":"integer"}],"content":[{"inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of t