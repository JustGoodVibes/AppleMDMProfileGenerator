{"abstract":[{"text":"The payload that configures a smart card.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"data","url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/SmartCard"},"sections":[],"seeAlsoSections":[{"title":"Security","identifiers":["doc://com.apple.devicemanagement/documentation/DeviceManagement/Passcode","doc://com.apple.devicemanagement/documentation/DeviceManagement/SecurityPreferences"],"generated":true,"anchor":"Security"}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["Unsupported OS: macOS"],"languages":["data"],"tokens":[{"kind":"text","text":"object "},{"kind":"identifier","text":"SmartCard"}]}],"kind":"declarations"},{"title":"Properties","items":[{"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.12.4","name":"allowSmartCard","attributes":[{"kind":"default","value":"true"}],"required":false,"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"0"},{"type":"text","text":": Turns off certificate trust check."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"1"},{"text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revocation checks.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"2","type":"codeVoice"},{"type":"text","text":": Turns on certi