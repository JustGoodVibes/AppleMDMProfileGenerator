{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"data","url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/SmartCard"},"seeAlsoSections":[{"title":"Security","generated":true,"anchor":"Security","identifiers":["doc://com.apple.devicemanagement/documentation/DeviceManagement/Passcode","doc://com.apple.devicemanagement/documentation/DeviceManagement/SecurityPreferences"]}],"primaryContentSections":[{"declarations":[{"languages":["data"],"platforms":["macOS"],"tokens":[{"text":"object ","kind":"text"},{"text":"SmartCard","kind":"identifier"}]}],"kind":"declarations"},{"kind":"properties","title":"Properties","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect.","type":"text"}]}],"attributes":[{"kind":"default","value":"true"}],"required":false,"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.12.4","name":"allowSmartCard"},{"introducedVersion":"10.12.4","type":[{"kind":"text","text":"integer"}],"name":"checkCertificateTrust","attributes":[{"value":"0","kind":"default"},{"kind":"allowedValues","values":["0","1","2","3"]}],"content":[{"inlineContent":[{"text":"Configures the certificate trust check and has one of the following possible values:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"0"},{"text":": Turns off certificate trust check.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"1","type":"codeVoice"},{"type":"text","text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revocation checks."}]}]},{"cont