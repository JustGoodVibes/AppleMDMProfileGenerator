t"}],"name":"tokenRemovalAction"},{"introducedVersion":"10.12.4","name":"UserPairing","type":[{"kind":"text","text":"boolean"}],"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", users don’t get the pairing dialog, although existing pairings still work."}],"type":"paragraph"}],"attributes":[{"kind":"default","value":"true"}],"required":false}],"kind":"properties"},{"content":[{"type":"heading","level":2,"anchor":"Discussion","text":"Discussion"},{"inlineContent":[{"text":"Specify ","type":"text"},{"type":"codeVoice","code":"com.apple.security.smartcard"},{"type":"text","text":" as the payload type."}],"type":"paragraph"},{"type":"heading","anchor":"Profile-availability","level":3,"text":"Profile availability"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"type":"paragraph","inlineContent":[]}]],[[{"inlineContent":[{"type":"text","text":"Device channel"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"User channel"}],"type":"paragraph"}],[{"inlineContent":[{"text":"NA","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Allow manual install","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Requires supervision","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"inlineContent":[{"type":"text","text":"Requires user-approved MDM"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"inlineContent":[{"text":"Allowed in user enrollment","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allow multiple payloads"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]]],"he