{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Device Management Profile","role":"symbol","platforms":[{"beta":false,"introducedAt":"10.12.4","name":"macOS"}],"modules":[{"name":"Device Management"}],"symbolKind":"dictionary","title":"SmartCard","externalID":"mdm-profiles:SmartCard","fragments":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"SmartCard"}],"navigatorTitle":[{"text":"SmartCard","kind":"identifier"}]},"seeAlsoSections":[{"generated":true,"anchor":"Security","identifiers":["doc://com.apple.devicemanagement/documentation/DeviceManagement/Passcode","doc://com.apple.devicemanagement/documentation/DeviceManagement/SecurityPreferences"],"title":"Security"}],"variants":[{"paths":["/documentation/devicemanagement/smartcard"],"traits":[{"interfaceLanguage":"data"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"object ","kind":"text"},{"text":"SmartCard","kind":"identifier"}],"languages":["data"],"platforms":["macOS"]}]},{"title":"Properties","items":[{"attributes":[{"value":"true","kind":"default"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect.","type":"text"}]}],"name":"allowSmartCard","type":[{"kind":"text","text":"boolean"}],"required":false,"introducedVersion":"10.12.4"},{"introducedVersion":"10.12.4","required":false,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"0"},{"type":"text","text":": Turns off certificate trust check."}],"type":"paragraph"}]},{"content":[{"typ