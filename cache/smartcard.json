":"false","type":"codeVoice"},{"type":"text","text":", users don’t get the pairing dialog, although existing pairings still work."}],"type":"paragraph"}],"attributes":[{"kind":"default","value":"true"}],"required":false,"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.12.4"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Specify "},{"code":"com.apple.security.smartcard","type":"codeVoice"},{"type":"text","text":" as the payload type."}]},{"anchor":"Profile-availability","level":3,"text":"Profile availability","type":"heading"},{"header":"row","extendedData":{"0_0":{"colspan":0,"rowspan":1},"0_1":{"rowspan":1,"colspan":0}},"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Device channel"}],"type":"paragraph"}],[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"User channel"}]}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Allow manual install"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Requires supervision","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"NA"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Requires user-approved MDM"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allowed in user enrollment"}]}],[{"inlineContent":[{"text":"NA","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Allow multiple payloads","type":"text"}]}],[{"inlineContent":[{"text":"NA","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"type":"headi