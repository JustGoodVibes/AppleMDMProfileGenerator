{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/SmartCard","interfaceLanguage":"data"},"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.devicemanagement/documentation/DeviceManagement"]]},"abstract":[{"type":"text","text":"The payload that configures a smart card."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Unsupported OS: macOS"],"tokens":[{"kind":"text","text":"object "},{"kind":"identifier","text":"SmartCard"}],"languages":["data"]}]},{"items":[{"attributes":[{"kind":"default","value":"true"}],"type":[{"text":"boolean","kind":"text"}],"introducedVersion":"10.12.4","content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect."}],"type":"paragraph"}],"name":"allowSmartCard","required":false},{"type":[{"text":"integer","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"text":"Configures the certificate trust check and has one of the following possible values:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"0"},{"type":"text","text":": Turns off certificate trust check."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1"},{"type":"text","text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revocation checks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"2"},{"text":": Turns on certificate trust check. A soft revocation check is also performed. Until the certificate is explicitly rejected by CRL/OCSP, it’s considered valid. This setting means that unavailable or unreachable CRL/OCSP allow this check to succeed.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"3","type":"codeVoice"},{"type":"text","text":": Turns on certificate trust check. A hard revocation check is also performed. Unless CRL/OCSP explicitly says “This certificate is OK,” it’s considered invalid. This option is the most secure."}],"type":"paragraph"}]}]}],"attributes":[{"kind":"default","value":"0"},{"values":["0","1","2","3"],"kind":"allowedValues"}],"introducedVersion":"10.12.4","required":false,"name":"checkCertificateTrust"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"type":"text","text":", a user can only log in or authenticate with a smart card. Available in macOS 10.13.2 and later."}]}],"attributes":[{"kind":"default","value":"false"}],"required":false,"type":[{"kind":"text","text":"boolean"}],"introducedVersion":"10.12.4","name":"enforceSmartCard"},{"attributes":[{"value":"false","kind":"default"}],"name":"oneCardPerUser","type":[{"kind":"text","text":"boolean"}],"content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"true","type":"codeVoice"},{"text":", a user can pair with only one smart card, although existing pairings are allowed if already set up.","type":"text"}]}],"required":false,"introducedVersion":"10.12.4"},{"name":"tokenRemovalAction","introducedVersion":"10.12.4","required":false,"type":[{"kind":"text","text":"integer"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"1","type":"codeVoice"},{"type":"text","text":", the system enables the screen saver when the smart card is removed. Available in macOS 10.13.4 and later."}]}],"attributes":[{"value":"0","kind":"default"},{"kind":"allowedValues","values":["0","1"]}]},{"name":"UserPairing","content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"text":", users don’t get the pairing dialog, although existing pairings still work.","type":"text"}],"type":"paragraph"}],"required":false,"attributes":[{"value":"true","kind":"default"}],"introducedVersion":"10.12.4","type":[{"kind":"text","text":"boolean"}]}],"kind":"properties","title":"Properties"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Specify ","type":"text"},{"type":"codeVoice","code":"com.apple.security.smartcard"},{"type":"text","text":" as the payload type."}]},{"text":"Profile availability","anchor":"Profile-availability","level":3,"type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Device channel"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"User channel","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Allow manual install","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Requires supervision"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"NA"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires user-approved MDM"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allowed in user enrollment"}]}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allow multiple payloads"}]}],[{"inlineContent":[{"type":"text","text":"NA"}],"type":"paragraph"}]]],"type":"table","header":"row","extendedData":{"0_1":{"colspan":0,"rowspan":1},"0_0":{"rows