","required":false,"introducedVersion":"10.12.4"},{"attributes":[{"value":"true","kind":"default"}],"introducedVersion":"10.12.4","required":false,"name":"UserPairing","type":[{"text":"boolean","kind":"text"}],"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", users don’t get the pairing dialog, although existing pairings still work."}],"type":"paragraph"}]}],"kind":"properties"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Specify "},{"type":"codeVoice","code":"com.apple.security.smartcard"},{"type":"text","text":" as the payload type."}]},{"anchor":"Profile-availability","type":"heading","level":3,"text":"Profile availability"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Device channel","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"User channel","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Allow manual install","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Requires supervision","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Requires user-approved MDM"}]}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Allowed in user enrollment"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"inlineContent":[{"text":"Allow multiple payloads","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text