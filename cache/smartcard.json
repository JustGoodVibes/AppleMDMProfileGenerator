{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"seeAlsoSections":[{"title":"Security","anchor":"Security","identifiers":["doc://com.apple.devicemanagement/documentation/DeviceManagement/Passcode","doc://com.apple.devicemanagement/documentation/DeviceManagement/SecurityPreferences"],"generated":true}],"abstract":[{"type":"text","text":"The payload that configures a smart card."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"SmartCard"}],"languages":["data"]}]},{"kind":"properties","title":"Properties","items":[{"type":[{"kind":"text","text":"boolean"}],"name":"allowSmartCard","required":false,"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect."}],"type":"paragraph"}],"attributes":[{"value":"true","kind":"default"}],"introducedVersion":"10.12.4"},{"type":[{"text":"integer","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"0"},{"type":"text","text":": Turns off certificate trust check."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1"},{"type":"text","text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revocation checks."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"2"},{"type":"text","text":": Turns on certificate trust check. A soft revocation check is also performed. Until the certificate is explic