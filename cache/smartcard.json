xt","text":", the system enables the screen saver when the smart card is removed. Available in macOS 10.13.4 and later."}],"type":"paragraph"}],"introducedVersion":"10.12.4","name":"tokenRemovalAction","type":[{"kind":"text","text":"integer"}],"required":false,"attributes":[{"kind":"default","value":"0"},{"values":["0","1"],"kind":"allowedValues"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"text":", users don’t get the pairing dialog, although existing pairings still work.","type":"text"}],"type":"paragraph"}],"attributes":[{"kind":"default","value":"true"}],"name":"UserPairing","type":[{"text":"boolean","kind":"text"}],"required":false,"introducedVersion":"10.12.4"}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Specify "},{"type":"codeVoice","code":"com.apple.security.smartcard"},{"type":"text","text":" as the payload type."}]},{"anchor":"Profile-availability","level":3,"text":"Profile availability","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[]}],[{"inlineContent":[],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"Device channel","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"User channel","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"NA","type":"text"}]}]],[[{"inlineContent":[{"text":"Allow manual install","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Requires supervision"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"NA"}]}]],[[{"inlineContent":[{"type":"text","text":"Requires user-approved MDM"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"NA"}],"type":"paragraph"}]],[[{"type":"par