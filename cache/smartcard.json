{"kind":"symbol","metadata":{"modules":[{"name":"Device Management"}],"symbolKind":"dictionary","role":"symbol","platforms":[{"name":"macOS","introducedAt":"10.12.4","beta":false},{"name":"Device Assignment Services","beta":false},{"name":"VPP License Management","beta":false}],"fragments":[{"kind":"text","text":"object "},{"text":"SmartCard","kind":"identifier"}],"externalID":"mdm-profiles:SmartCard","navigatorTitle":[{"kind":"identifier","text":"SmartCard"}],"roleHeading":"Device Management Profile","title":"SmartCard"},"seeAlsoSections":[{"generated":true,"anchor":"Security","title":"Security","identifiers":["doc://com.apple.devicemanagement/documentation/DeviceManagement/Passcode","doc://com.apple.devicemanagement/documentation/DeviceManagement/SecurityPreferences"]}],"abstract":[{"text":"The payload that configures a smart card.","type":"text"}],"identifier":{"url":"doc://com.apple.devicemanagement/documentation/DeviceManagement/SmartCard","interfaceLanguage":"data"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["data"],"tokens":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"SmartCard"}],"platforms":["Unsupported OS: macOS"]}],"kind":"declarations"},{"title":"Properties","kind":"properties","items":[{"introducedVersion":"10.12.4","required":false,"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect."}],"type":"paragraph"}],"type":[{"text":"boolean","kind":"text"}],"attributes":[{"kind":"default","value":"true"}],"name":"allowSmartCard"},{"type":[{"kind":"text","text":"integer"}],"content":[{"inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"0"},{"type":"text","text":": Turns off certificate trust check."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"1"},{"text":": Turns on certificate trust check. A standard validity check is performed but doesn’t include additional revocation checks.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"2","type":"codeVoice"},{"type":"text","text":": Turns on certificate trust check. A soft revocation check is also performed. Until the certificate is explicitly rejected by CRL/OCSP, it’s considered valid. This setting means that unavailable or unreachable CRL/OCSP allow this check to succeed."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"3"},{"type":"text","text":": Turns on certificate trust check. A hard revocation check is also performed. Unless CRL/OCSP explicitly says “This certificate is OK,” it’s considered invalid. This option is the most secure."}]}]}]}],"required":false,"attributes":[{"kind":"default","value":"0"},{"kind":"allowedValues","values":["0","1","2","3"]}],"introducedVersion":"10.12.4","name":"checkCertificateTrust"},{"introducedVersion":"10.12.4","name":"enforceSmartCard","type":[{"kind":"text","text":"boolean"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"true","type":"codeVoice"},{"text":", a user can only log in or authenticate with a smart card. Available in macOS 10.13.2 and later.","type":"text"}]}],"required":false,"attributes":[{"kind":"default","value":"false"}]},{"required":false,"name":"oneCardPerUser","type":[{"kind":"text","text":"boolean"}],"attributes":[{"kind":"default","value":"false"}],"introducedVersion":"10.12.4","content":[{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", a user can pair with only one smart card, although existing pairings are allowed if already set up.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"1","type":"codeVoice"},{"text":", the system enables the screen saver when the smart card is removed. Available in macOS 10.13.4 and later.","type":"text"}]}],"attributes":[{"value":"0","kind":"default"},{"values":["0","1"],"kind":"allowedValues"}],"introducedVersion":"10.12.4","name":"tokenRemovalAction","type":[{"text":"integer","kind":"text"}],"required":false},{"content":[{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":", users don’t get the pairing dialog, although existing pairings still work."}],"type":"paragraph"}],"required":false,"introducedVersion":"10.12.4","attributes":[{"kind":"default","value":"true"}],"type":[{"text":"boolean","kind":"text"}],"name":"UserPairing"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"Discussion","type":"heading"},{"inlineContent":[{"text":"Specify ","type":"text"},{"type":"codeVoice","code":"com.apple.security.smartcard"},{"type":"text","text":" as the payload type."}],"type":"paragraph"},{"anchor":"Profile-availability","level":3,"text":"Profile availability","type":"heading"},{"extendedData":{"0_1":{"colspan":0,"rowspan":1},"0_0":{"colspan":0,"rowspan":1}},"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[]}],[{"inlineContent":[],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Device channel"}]}],[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"User channel","type":"text"}]}],[{"inlineContent":[{"text":"NA","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Allow manual install"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}]],[[{"inlineContent":[{"type":"text","text":"R