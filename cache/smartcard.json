{"hierarchy":{"paths":[["doc://com.apple.documentation/documentation/technologies","doc://com.apple.devicemanagement/documentation/DeviceManagement"]]},"variants":[{"traits":[{"interfaceLanguage":"data"}],"paths":["/documentation/devicemanagement/smartcard"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","fragments":[{"text":"object ","kind":"text"},{"kind":"identifier","text":"SmartCard"}],"platforms":[{"name":"macOS","introducedAt":"10.12.4","beta":false},{"beta":false,"name":"Device Assignment Services"},{"beta":false,"name":"VPP License Management"}],"title":"SmartCard","navigatorTitle":[{"kind":"identifier","text":"SmartCard"}],"symbolKind":"dictionary","modules":[{"name":"Device Management"}],"externalID":"mdm-profiles:SmartCard","roleHeading":"Device Management Profile"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["data"],"platforms":["Unsupported OS: macOS"],"tokens":[{"text":"object ","kind":"text"},{"text":"SmartCard","kind":"identifier"}]}]},{"title":"Properties","kind":"properties","items":[{"required":false,"name":"allowSmartCard","type":[{"text":"boolean","kind":"text"}],"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":", the system disables smart cards for logins, authorizations, and screen saver unlocking. It is still allowed for other functions, such as signing emails and accessing the web. A restart is required for a setting change to take effect."}],"type":"paragraph"}],"attributes":[{"kind":"default","value":"true"}],"introducedVersion":"10.12.4"},{"name":"checkCertificateTrust","type":[{"text":"integer","kind":"text"}],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configures the certificate trust check and has one of the following possible values:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"0"},{"text":": Turns off certificate trust check.","ty